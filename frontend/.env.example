# Copy to .env.local for local development.

# Base URL of the breadcrumbs backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase (Project Settings -> API in the Supabase dashboard).
# URL: the "Project URL". KEY: the "anon" / "publishable" public key.
# These are public client keys and are safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YcpOUR-ANON-PUBLIC-KEY]
