# Copy to .env and adjust as needed. All variables are optional and fall
# back to the defaults defined in app/core/config.py.

BREADCRUMBS_APP_NAME=breadcrumbs
BREADCRUMBS_ENVIRONMENT=development
BREADCRUMBS_DEBUG=true

# Logging
BREADCRUMBS_LOG_LEVEL=INFO
BREADCRUMBS_LOG_JSON=false

# HTTP server
BREADCRUMBS_HOST=0.0.0.0
BREADCRUMBS_PORT=8000

# Comma-separated list of allowed CORS origins (the frontend).
BREADCRUMBS_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (Supabase Postgres) -- REQUIRED for running the app and migrations.
# Get this from the Supabase dashboard: Project Settings -> Database ->
# Connection string -> "URI". Replace [YOUR-PASSWORD] with your DB password
# and prefix the scheme with "+psycopg2".
#
# Direct connection (port 5432):
#   BREADCRUMBS_DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Connection pooler (port 6543, recommended for serverless):
#   BREADCRUMBS_DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# NOTE: This is the ONLY secret required for Phase 2. Do not commit your .env.
BREADCRUMBS_DATABASE_URL=

# Log SQL statements (verbose; development only).
BREADCRUMBS_DATABASE_ECHO=false

# ---------------------------------------------------------------------------
# Supabase Auth -- REQUIRED for authenticated routes.
# ---------------------------------------------------------------------------
# Your Supabase project URL (Project Settings -> API -> Project URL).
BREADCRUMBS_SUPABASE_URL=https://[PROJECT-REF].supabase.co

# JWT verification strategy (choose ONE):
#
# (A) Legacy HS256 shared secret. Set this to the value from
#     Project Settings -> API -> JWT Settings -> "JWT Secret".
#     Leave blank to use strategy (B).
BREADCRUMBS_SUPABASE_JWT_SECRET=
#
# (B) Asymmetric keys (RS256/ES256). If JWT_SECRET above is blank, the backend
#     fetches public keys from <SUPABASE_URL>/auth/v1/.well-known/jwks.json
#     automatically. Nothing else to configure.

# Expected audience claim (leave as-is for standard Supabase user tokens).
BREADCRUMBS_SUPABASE_JWT_AUDIENCE=authenticated

# ---------------------------------------------------------------------------
# Claude (optional) — knowledge builder architecture extraction
# ---------------------------------------------------------------------------
# When set, the knowledge builder may call Claude for structured proposals.
# When unset, a deterministic rule-based extractor is used (fine for dev/tests).
BREADCRUMBS_ANTHROPIC_API_KEY=
BREADCRUMBS_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Vector search / organizational memory (Phase 7)
# ---------------------------------------------------------------------------
# The default embedder is a deterministic local hashing model (offline, no API).
# Bump EMBEDDING_VERSION to force re-embedding of all objects.
BREADCRUMBS_EMBEDDING_MODEL=local-hash
BREADCRUMBS_EMBEDDING_VERSION=v1
BREADCRUMBS_EMBEDDING_DIMENSIONS=256

# ---------------------------------------------------------------------------
# Real integrations (optional — Phase 11 GitHub + Render)
# ---------------------------------------------------------------------------
# Tokens are read from the backend environment ONLY. They are never stored in
# the database and never returned to the frontend. When a token is blank, the
# investigation engine transparently falls back to the fake collector for that
# provider, so the app runs fully offline in dev/tests.
#
# GitHub: a fine-grained or classic PAT with read access to the repos you want
# to correlate (contents + pull requests). https://github.com/settings/tokens
BREADCRUMBS_GITHUB_TOKEN=
BREADCRUMBS_GITHUB_API_BASE=https://api.github.com
# Optional default "owner/repo" used when an incident has no repo hint.
BREADCRUMBS_GITHUB_DEFAULT_REPO=
#
# Render: an API key from Account Settings -> API Keys. https://render.com
BREADCRUMBS_RENDER_API_KEY=
BREADCRUMBS_RENDER_API_BASE=https://api.render.com/v1
# Optional owner id to scope Render service lookups.
BREADCRUMBS_RENDER_OWNER_ID=

# ---------------------------------------------------------------------------
# Langfuse observability (optional — Phase 9 incident reasoning)
# ---------------------------------------------------------------------------
BREADCRUMBS_LANGFUSE_PUBLIC_KEY=
BREADCRUMBS_LANGFUSE_SECRET_KEY=
BREADCRUMBS_LANGFUSE_HOST=https://cloud.langfuse.com
